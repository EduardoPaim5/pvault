{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "PVAULT_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "asan-ubsan",
      "displayName": "ASan + UBSan",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/asan-ubsan",
      "cacheVariables": {
        "PVAULT_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON",
        "PVAULT_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "fuzz",
      "displayName": "Fuzzers",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/fuzz",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang",
        "BUILD_TESTING": "OFF",
        "PVAULT_BUILD_FUZZERS": "ON",
        "PVAULT_ENABLE_HARDENING": "OFF",
        "PVAULT_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "asan-ubsan", "configurePreset": "asan-ubsan" },
    { "name": "release", "configurePreset": "release" },
    { "name": "fuzz", "configurePreset": "fuzz" }
  ],
  "testPresets": [
    { "name": "debug", "configurePreset": "debug", "output": { "outputOnFailure": true } },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan",
      "environment": { "ASAN_OPTIONS": "detect_leaks=0" },
      "output": { "outputOnFailure": true }
    },
    { "name": "release", "configurePreset": "release", "output": { "outputOnFailure": true } }
  ]
}
